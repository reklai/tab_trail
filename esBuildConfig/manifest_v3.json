{
  "manifest_version": 3,
  "name": "TabTrail - Current Tab History",
  "version": "1.0.0",
  "description": "Press Alt+H to show this tab's page trail and jump back to any visited step without pressing Back over and over.",
  "minimum_chrome_version": "89",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "optionsPage/optionsPage.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png",
      "96": "icons/icon-96.png"
    },
    "default_popup": "toolbarPopup/toolbarPopup.html",
    "default_title": "TabTrail"
  },
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
