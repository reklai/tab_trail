{
  "name": "tabtrail-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Stop losing your place in a tab. See your current tab history, preview earlier pages, and jump back without repeated Back clicks.",
  "license": "MIT",
  "scripts": {
    "build": "node esBuildConfig/build.mjs",
    "build:firefox": "node esBuildConfig/build.mjs --target firefox",
    "build:chrome": "node esBuildConfig/build.mjs --target chrome",
    "watch": "node esBuildConfig/build.mjs --watch",
    "watch:firefox": "node esBuildConfig/build.mjs --watch --target firefox",
    "watch:chrome": "node esBuildConfig/build.mjs --watch --target chrome",
    "lint": "node esBuildConfig/lint.mjs",
    "test": "node --test test/*.test.mjs",
    "test:browser:firefox": "node test/browser/overlay-precedence.mjs firefox",
    "test:browser:chrome": "node test/browser/overlay-precedence.mjs chrome",
    "typecheck": "tsc --noEmit",
    "verify:compat": "node esBuildConfig/verifyCompat.mjs",
    "verify:upgrade": "node esBuildConfig/verifyUpgrade.mjs",
    "verify:store": "node esBuildConfig/verifyStore.mjs",
    "release:package": "node esBuildConfig/packageRelease.mjs",
    "ci": "npm run lint && npm run test && npm run typecheck && npm run verify:compat && npm run verify:upgrade && npm run verify:store && npm run build:firefox && npm run build:chrome",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.4",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "selenium-webdriver": "^4.45.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
